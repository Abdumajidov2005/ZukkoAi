# ============================================================
# ZUKKO AI — Environment configuration
# Copy this file to ".env" and fill in your values.
# ============================================================

# Your backend API base URL (no trailing slash).
# Example: https://api.yourdomain.com  or  http://localhost:8000/api
VITE_API_BASE_URL=http://localhost:8000/api

# Run on mock data (true) or talk to the real backend (false).
# Keep "true" for the demo. Set to "false" once your API is ready.
VITE_USE_MOCK=true
